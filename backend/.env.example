# Copy to .env and fill in values. Never commit .env.
# Default is Neon Postgres (psycopg3 driver, sslmode=require).
# To use SQLite locally instead, comment this line out — database.py falls
# back to sqlite:///./meetpilot.db when DATABASE_URL is unset.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

REDIS_URL=redis://localhost:6379/0

# Gemini (Subsystem 3 extraction)
GOOGLE_API_KEY=

# Google OAuth (Auth backend — Phase A of Auth_And_Session_Linking_Plan)
# Get GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client ID, Web application).
# Authorized redirect URI in the console must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Where the OAuth callback lands the user after a successful sign-in.
# The frontend's /auth/callback page reads `?token=` and stores it.
AUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/auth/callback
# Random 32-byte hex; generate one per environment:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SESSION_SECRET=

# --- Production only (leave blank/unset for local dev) ---
# Comma-separated exact frontend origins allowed by CORS in production, e.g.
#   FRONTEND_ORIGINS=https://meetpilot.vercel.app
# localhost:3000 is always allowed regardless, for local dev.
FRONTEND_ORIGINS=
# Set to "true" in production (HTTPS) so the OAuth session cookie is Secure.
COOKIE_SECURE=false
