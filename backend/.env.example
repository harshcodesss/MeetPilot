# Copy to .env and fill in values. Never commit .env.
# Switch to Postgres before integration: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///./meetpilot.db

REDIS_URL=redis://localhost:6379/0

# Gemini (Subsystem 3 extraction)
GOOGLE_API_KEY=

# Google OAuth (Auth backend — Phase A of Auth_And_Session_Linking_Plan)
# Get GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client ID, Web application).
# Authorized redirect URI in the console must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Dev-landing fallback — the paste-token page used by the extension while the
# frontend is being built. Phase 10 Step A removes this and the dev landing.
AUTH_SUCCESS_REDIRECT_URL=http://localhost:8000/auth/dev/landing
# Frontend callback — preferred over the dev landing when set. Phase 2 wires
# the OAuth callback to redirect here so sign-in lands the user inside the
# Next.js app at `/auth/callback?token=...`.
AUTH_SUCCESS_REDIRECT_URL_FRONTEND=http://localhost:3000/auth/callback
# Random 32-byte hex; generate one per environment:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SESSION_SECRET=
