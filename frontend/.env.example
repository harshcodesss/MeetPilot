# Copy to .env.local for local dev. In production set this in the Vercel
# project's Environment Variables instead.
#
# Origin of the FastAPI backend. Defaults to http://localhost:8000 when unset
# (see src/lib/api.ts). In production point it at the deployed backend, e.g.
#   NEXT_PUBLIC_API_BASE_URL=https://meetpilot-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
